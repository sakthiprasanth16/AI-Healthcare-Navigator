# ── AI Healthcare Cost Navigator — Backend Environment Variables ───────────
# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored and dockerignored — never commit real secrets.

# MongoDB Atlas connection string.
# Get this from Atlas → Database → Connect → "Drivers" → copy URI, then
# replace <username>, <password>, and the db name at the end of the path.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/healthcare_navigator?retryWrites=true&w=majority

# Database name (Motor uses this to select the db from the client)
DATABASE_NAME=healthcare_navigator

# Google Gemini API key — used by UC1 (lab recommendation text) and UC2
# (prescription extraction, pharmacy recommendation). NOT used by UC3 (Session 3
# removed Gemini from Spending Tracker — it's rule-based now).
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouteService API key — used for real driving distance/time (UC1 labs,
# UC2 pharmacy distance). Falls back to haversine calculation if missing/down.
# Get one at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# JWT secret for auth token signing — generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_long_random_string

# JWT algorithm + token expiry
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — comma-separated origins allowed to call this API.
# In docker-compose, the frontend is served on port 80, so include that origin
# alongside local dev ports.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80,http://localhost
